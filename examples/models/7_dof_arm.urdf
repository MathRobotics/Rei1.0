<?xml version="1.0"?>
<robot name="7_dof_arm">
  <material name="base_gray">
    <color rgba="0.35 0.35 0.38 1.0"/>
  </material>
  <material name="link_orange">
    <color rgba="0.90 0.45 0.16 1.0"/>
  </material>
  <material name="joint_blue">
    <color rgba="0.20 0.42 0.78 1.0"/>
  </material>
  <material name="ee_teal">
    <color rgba="0.12 0.62 0.62 1.0"/>
  </material>

  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.10"/>
      </geometry>
      <material name="base_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="base_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.00" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="base_gray"/>
    </visual>
  </link>

  <link name="arm1">
